// ==UserScript==
// @name         Tallos Categorias
// @namespace    tallos.chat
// @version      27.0.0
// @match        https://app.tallos.com.br/app/chat*
// @grant        none
// ==/UserScript==

(() => {
'use strict';

const TOOLBAR_SELECTOR = '.ql-toolbar.ql-snow';
const EDITOR_SELECTOR = '.ql-editor';
const LS_CATS = 'tallos_categorias';

const getCats = () => JSON.parse(localStorage.getItem(LS_CATS) || '[]');
const saveCats = cats => localStorage.setItem(LS_CATS, JSON.stringify(cats));

function inserirTexto(texto) {
    const editor = document.querySelector(EDITOR_SELECTOR);
    if (!editor) return;

    editor.innerHTML = texto
        .split('\n')
        .map(l => l.trim() ? `<p>${l}</p>` : '<p><br></p>')
        .join('');

    editor.dispatchEvent(new Event('input', { bubbles: true }));
}

function copiar(txt) {
    navigator.clipboard.writeText(txt);
}

function abrirModal(msg = {}, callback) {
    const overlay = document.createElement('div');
    overlay.style.cssText = `
        position:fixed;
        inset:0;
        background:rgba(0,0,0,.45);
        display:flex;
        justify-content:center;
        align-items:center;
        z-index:999999;
    `;

    const modal = document.createElement('div');
    modal.style.cssText = `
        background:#fff;
        width:500px;
        max-width:95%;
        padding:15px;
        border-radius:12px;
    `;

    modal.innerHTML = `
        <h3>Mensagem</h3>
        <input id="titulo" placeholder="Emoji" value="${msg.titulo || ''}"
            style="width:100%;padding:8px;margin-bottom:10px;">
        <textarea id="texto"
            style="width:100%;height:180px;padding:8px;">${msg.texto || ''}</textarea>
        <div style="margin-top:10px;display:flex;gap:10px;justify-content:flex-end;">
            <button id="cancelar">Cancelar</button>
            <button id="salvar">Salvar</button>
        </div>
    `;

    overlay.appendChild(modal);
    document.body.appendChild(overlay);

    modal.querySelector('#cancelar').onclick = () => overlay.remove();

    modal.querySelector('#salvar').onclick = () => {
        const titulo = modal.querySelector('#titulo').value.trim();
        const texto = modal.querySelector('#texto').value.trim();

        if (!titulo || !texto) return alert('Preencha tudo');

        callback({ titulo, texto });
        overlay.remove();
    };
}

function exportarCategorias() {
    const cats = getCats();
    const blob = new Blob([JSON.stringify(cats, null, 2)], {
        type: 'application/json'
    });

    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'tallos_categorias.json';
    a.click();

    URL.revokeObjectURL(a.href);
}

function importarCategorias() {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';

    input.onchange = () => {
        const file = input.files[0];
        if (!file) return;

        const reader = new FileReader();

        reader.onload = () => {
            try {
                const dados = JSON.parse(reader.result);
                if (!Array.isArray(dados)) return alert('Arquivo inválido');

                saveCats(dados);
                montarBarra(true);
            } catch {
                alert('Erro ao importar');
            }
        };

        reader.readAsText(file);
    };

    input.click();
}

function adicionarCategoria() {
    const overlay = document.createElement('div');
    overlay.style.cssText = `
        position:fixed;
        inset:0;
        background:rgba(0,0,0,.45);
        display:flex;
        justify-content:center;
        align-items:center;
        z-index:999999;
    `;

    const modal = document.createElement('div');
    modal.style.cssText = `
        background:#fff;
        width:320px;
        max-width:95%;
        padding:20px;
        border-radius:12px;
        display:flex;
        flex-direction:column;
        gap:10px;
    `;

    modal.innerHTML = `
        <h3 style="margin:0;">Opções</h3>

        <button id="nova">➕ Nova categoria</button>
        <button id="exportar">📤 Exportar</button>
        <button id="importar">📥 Importar</button>
        <button id="fechar">Cancelar</button>
    `;

    overlay.appendChild(modal);
    document.body.appendChild(overlay);

    modal.querySelectorAll('button').forEach(btn => {
        btn.style.cssText = `
            padding:10px;
            border:none;
            border-radius:8px;
            cursor:pointer;
            background:#f5f5f5;
        `;
    });

    modal.querySelector('#fechar').onclick = () => overlay.remove();

    modal.querySelector('#exportar').onclick = () => {
        exportarCategorias();
        overlay.remove();
    };

    modal.querySelector('#importar').onclick = () => {
        importarCategorias();
        overlay.remove();
    };

    modal.querySelector('#nova').onclick = () => {
        overlay.remove();

        const nome = prompt('Nome da categoria:');
        const icon = prompt('Emoji da categoria:');

        if (!nome || !icon) return;

        const cats = getCats();

        cats.push({
            id: Date.now(),
            nome,
            icon,
            mensagens: []
        });

        saveCats(cats);
        montarBarra(true);
    };
}

function adicionarMensagem(catId) {
    abrirModal({}, ({ titulo, texto }) => {
        const cats = getCats();
        const cat = cats.find(c => c.id === catId);

        cat.mensagens.push({
            id: Date.now(),
            titulo,
            texto
        });

        saveCats(cats);
        montarBarra(true);
    });
}

function editarMensagem(catId, msgId) {
    const cats = getCats();
    const cat = cats.find(c => c.id === catId);
    const msg = cat.mensagens.find(m => m.id === msgId);

    abrirModal(msg, ({ titulo, texto }) => {
        msg.titulo = titulo;
        msg.texto = texto;

        saveCats(cats);
        montarBarra(true);
    });
}

function excluirMensagem(catId, msgId) {
    const cats = getCats();
    const cat = cats.find(c => c.id === catId);

    cat.mensagens = cat.mensagens.filter(m => m.id !== msgId);

    saveCats(cats);
    montarBarra(true);
}

function fecharTodos() {
    document.querySelectorAll('.submenu-tallos').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.controle-tallos').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.msg-controles').forEach(el => el.style.display = 'none');
}

function criarBotaoControle(icon, onClick) {
    const b = document.createElement('button');
    b.innerHTML = icon;
    b.style.cssText = `
        width:28px;
        height:28px;
        border:none;
        background:#fff;
        border-radius:6px;
        cursor:pointer;
        box-shadow:0 2px 6px rgba(0,0,0,.12);
    `;
    b.onclick = onClick;
    return b;
}

function montarBarra(refresh = false) {
    const toolbar = document.querySelector(TOOLBAR_SELECTOR);
    if (!toolbar) return;

    let grupo = document.getElementById('tallos-categorias');

    if (grupo && refresh) grupo.remove();
    if (grupo) return;

    grupo = document.createElement('div');
    grupo.id = 'tallos-categorias';
    grupo.style.cssText = `display:flex;gap:6px;align-items:center;`;

    const plus = document.createElement('button');
    plus.innerHTML = '➕';
    plus.onclick = adicionarCategoria;
    grupo.appendChild(plus);

    getCats().forEach(cat => {
        const wrap = document.createElement('div');
        wrap.style.cssText = `position:relative;display:flex;align-items:center;justify-content:center;`;

        const btnMain = document.createElement('button');
        btnMain.innerHTML = cat.icon;
        btnMain.title = cat.nome;

        const controles = document.createElement('div');
        controles.className = 'controle-tallos';
        controles.style.cssText = `
            position:absolute;
            left:40px;
            display:none;
            flex-direction:row;
            gap:4px;
            z-index:999999;
        `;

        controles.appendChild(criarBotaoControle('✏️', () => {
    const overlay = document.createElement('div');
    overlay.style.cssText = `
        position:fixed;
        inset:0;
        background:rgba(0,0,0,.45);
        display:flex;
        justify-content:center;
        align-items:center;
        z-index:999999;
    `;

    const modal = document.createElement('div');
    modal.style.cssText = `
        background:#fff;
        width:400px;
        max-width:95%;
        padding:15px;
        border-radius:12px;
    `;

    modal.innerHTML = `
        <h3>Editar categoria</h3>

        <input id="nome"
            value="${cat.nome}"
            placeholder="Nome da categoria"
            style="width:100%;padding:8px;margin-bottom:10px;">

        <input id="emoji"
            value="${cat.icon}"
            placeholder="Emoji"
            style="width:100%;padding:8px;margin-bottom:10px;">

        <div style="display:flex;gap:10px;justify-content:flex-end;">
            <button id="cancelar">Cancelar</button>
            <button id="salvar">Salvar</button>
        </div>
    `;

    overlay.appendChild(modal);
    document.body.appendChild(overlay);

    modal.querySelector('#cancelar').onclick = () => overlay.remove();

    modal.querySelector('#salvar').onclick = () => {
        const novoNome = modal.querySelector('#nome').value.trim();
        const novoEmoji = modal.querySelector('#emoji').value.trim();

        if (!novoNome || !novoEmoji) return alert('Preencha tudo');

        cat.nome = novoNome;
        cat.icon = novoEmoji;

        saveCats(getCats().map(c => c.id === cat.id ? cat : c));
        montarBarra(true);
        overlay.remove();
    };
}));

        controles.appendChild(criarBotaoControle('🗑️', () => {
            saveCats(getCats().filter(c => c.id !== cat.id));
            montarBarra(true);
        }));

        controles.appendChild(criarBotaoControle('➕', () => adicionarMensagem(cat.id)));

        const coluna = document.createElement('div');
        coluna.className = 'submenu-tallos';
        coluna.style.cssText = `
            position:absolute;
            bottom:100%;
            left:50%;
            transform:translateX(-50%);
            display:none;
            flex-direction:column-reverse;
            gap:4px;
            margin-bottom:6px;
            z-index:999999;
        `;

        cat.mensagens.forEach(msg => {
            const msgWrap = document.createElement('div');
            msgWrap.style.cssText = `
                position:relative;
                display:flex;
                align-items:center;
            `;

            const msgControles = document.createElement('div');
            msgControles.className = 'msg-controles';
            msgControles.style.cssText = `
                position:absolute;
                left:40px;
                display:none;
                flex-direction:row;
                gap:4px;
                z-index:999999;
            `;

            msgControles.appendChild(criarBotaoControle('✏️', () => {
                editarMensagem(cat.id, msg.id);
            }));

            msgControles.appendChild(criarBotaoControle('🗑️', () => {
                excluirMensagem(cat.id, msg.id);
            }));

            msgControles.appendChild(criarBotaoControle('📋', () => {
                copiar(msg.texto);
            }));

            const b = document.createElement('button');
            b.innerHTML = msg.titulo;
            b.title = `${msg.titulo} - ${msg.texto}`;

            b.style.cssText = `
                width:34px;
                height:34px;
                border:none;
                background:#fff;
                border-radius:8px;
                cursor:pointer;
                box-shadow:0 2px 6px rgba(0,0,0,.12);
            `;

            b.onclick = e => {
                e.stopPropagation();
                inserirTexto(msg.texto);
                fecharTodos();
            };

            b.oncontextmenu = e => {
                e.preventDefault();
                e.stopPropagation();

                document.querySelectorAll('.msg-controles').forEach(el => {
                    el.style.display = 'none';
                });

                msgControles.style.display =
                    msgControles.style.display === 'flex' ? 'none' : 'flex';
            };

            msgWrap.appendChild(msgControles);
            msgWrap.appendChild(b);

            coluna.appendChild(msgWrap);
        });

        btnMain.onclick = e => {
            e.stopPropagation();

            const aberto = coluna.style.display === 'flex';
            fecharTodos();
            coluna.style.display = aberto ? 'none' : 'flex';
        };

        btnMain.oncontextmenu = e => {
            e.preventDefault();
            e.stopPropagation();

            fecharTodos();
            controles.style.display = 'flex';
        };

        wrap.appendChild(controles);
        wrap.appendChild(coluna);
        wrap.appendChild(btnMain);

        grupo.appendChild(wrap);
    });

    document.addEventListener('click', fecharTodos);

    toolbar.insertBefore(grupo, toolbar.firstChild);
}

new MutationObserver(() => montarBarra()).observe(document.body, {
    childList: true,
    subtree: true
});

montarBarra();

})();
